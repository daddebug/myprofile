# Public, read-only Unity payload URLs generated by the Blob upload script.
VITE_UNITY_DATA_URL=
VITE_UNITY_FRAMEWORK_URL=
VITE_UNITY_WASM_URL=
VITE_UNITY_STREAMING_ASSETS_URL=

# Local upload credential only. Never expose this as a VITE_ variable.
BLOB_READ_WRITE_TOKEN=

# Secure CLI alternative: `vercel link` supplies OIDC; pair it with the Blob store ID.
VERCEL_OIDC_TOKEN=
BLOB_STORE_ID=
